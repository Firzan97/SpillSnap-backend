# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://spendsnap:password@localhost:5432/spendsnap
DB_HOST=localhost
DB_PORT=5432
DB_USER=spendsnap
DB_PASS=password
DB_NAME=spendsnap

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Supabase owns sign-up / login / Google / Apple SSO. The backend only verifies
# the access token Supabase issues. Find these in the Supabase Dashboard:
#   Settings → API
SUPABASE_URL=https://xxxx.supabase.co
# Settings → API → JWT Secret (used to verify the HS256 access token)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
# Settings → API → Project API keys (anon = client, service_role = server admin)
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google/Apple credentials are NOT set here — paste them into
# Supabase Dashboard → Authentication → Providers.

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
# Pro is sold on the web via Stripe (auto-renewing subscription).
#   Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxxx
#   Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxx
#   Recurring Prices (MYR) on the Pro Product
STRIPE_PRICE_PRO_MONTHLY=price_xxxx
STRIPE_PRICE_PRO_ANNUAL=price_xxxx

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Used for Stripe success/cancel/return URLs too.
FRONTEND_URL=http://localhost:8081

# ── Storage (Supabase Storage) ────────────────────────────────────────────────
# Uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY above. Create a (private) bucket.
STORAGE_BUCKET=receipts
# Public bucket for profile avatars (must be PUBLIC — served via stable public URL).
AVATAR_BUCKET=avatars

# ── Receipt extraction (Claude vision) ────────────────────────────────────────
# console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── WhatsApp (Meta Cloud API) — Pro receipt upload via WhatsApp ────────────────
# Inert until WHATSAPP_PHONE_NUMBER_ID + WHATSAPP_ACCESS_TOKEN are set.
# Meta: developers.facebook.com → your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=          # "Phone number ID" (NOT the phone number)
WHATSAPP_ACCESS_TOKEN=             # Permanent System User token (whatsapp_business_messaging)
WHATSAPP_VERIFY_TOKEN=            # Any random string you choose; paste the same one in Meta's webhook config
WHATSAPP_APP_SECRET=              # App → Settings → Basic → App Secret (validates webhook signature)
WHATSAPP_API_VERSION=v21.0
# Proactive Pro-welcome ping (cold message → must be a Meta-approved template).
# Create + approve a template in Meta → WhatsApp → Message Templates, then set its name.
# Leave blank to disable the ping. Template body should have one variable {{1}} = first name.
WHATSAPP_WELCOME_TEMPLATE=        # e.g. pro_welcome
WHATSAPP_TEMPLATE_LANG=en         # template language code (e.g. en, en_US, ms)
