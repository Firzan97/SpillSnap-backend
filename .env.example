# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://spillsnap:password@localhost:5432/spillsnap
# Or set the discrete fields instead of DATABASE_URL (used when DATABASE_URL is unset):
DB_HOST=localhost
DB_PORT=5432
DB_USER=spillsnap
DB_PASS=password
DB_NAME=spillsnap

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Clerk owns sign-up / login / Google SSO / email verification / password reset.
# The backend only verifies the session token Clerk issues to the client.
# Find these in the Clerk Dashboard → API keys.
#   Backend API key (server secret — never expose to the client).
CLERK_SECRET_KEY=sk_test_xxxx
#   Issuer = your Frontend API URL. Dev looks like https://your-app.clerk.accounts.dev;
#   production looks like https://clerk.yourdomain.com. Backend fetches its JWKS
#   from <issuer>/.well-known/jwks.json to verify the RS256 session token.
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# Google credentials are NOT set here — configure the Google connection in
# Clerk Dashboard → User & Authentication → Social Connections.

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Auth moved to Clerk, but receipt images + avatars still live in Supabase
# Storage. Find these in Supabase Dashboard → Settings → API.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
# Pro is sold on the web via Stripe (auto-renewing subscription).
#   Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxxx
#   Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxx
#   Recurring Prices (MYR) on the Pro Product
STRIPE_PRICE_PRO_MONTHLY=price_xxxx
STRIPE_PRICE_PRO_ANNUAL=price_xxxx

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Used for Stripe success/cancel/return URLs too.
FRONTEND_URL=http://localhost:8081
# Public website origin hosting the Stripe success/cancel pages (Nuxt site).
# Mobile checkout lands here, then the page deep-links back into the app.
WEB_URL=https://spillsnap.com

# ── Storage (Supabase Storage) ────────────────────────────────────────────────
# Uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY above. Create a (private) bucket.
STORAGE_BUCKET=receipts
# Public bucket for profile avatars (must be PUBLIC — served via stable public URL).
AVATAR_BUCKET=avatars

# ── Receipt extraction (Claude vision) ────────────────────────────────────────
# console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-xxxx
# Speed/cost tuning (optional). Long edge images are downscaled to (px) before the
# model call — smaller = fewer vision tokens = faster/cheaper, but watch small-text
# legibility. Below the confidence threshold a WhatsApp scan escalates to the
# accurate model (the app path never escalates — the user edits the draft).
RECEIPT_MAX_EDGE_PX=1280
RECEIPT_CONFIDENCE_THRESHOLD=70

# ── WhatsApp (Meta Cloud API) — Pro receipt upload via WhatsApp ────────────────
# Inert until WHATSAPP_PHONE_NUMBER_ID + WHATSAPP_ACCESS_TOKEN are set.
# Meta: developers.facebook.com → your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=          # "Phone number ID" (NOT the phone number)
WHATSAPP_ACCESS_TOKEN=             # Permanent System User token (whatsapp_business_messaging)
WHATSAPP_VERIFY_TOKEN=            # Any random string you choose; paste the same one in Meta's webhook config
WHATSAPP_APP_SECRET=              # App → Settings → Basic → App Secret (validates webhook signature)
WHATSAPP_API_VERSION=v21.0
# Proactive Pro-welcome ping (cold message → must be a Meta-approved template).
# Create + approve a template in Meta → WhatsApp → Message Templates, then set its name.
# Leave blank to disable the ping. Template body should have one variable {{1}} = first name.
# Reused for BOTH the Pro-welcome ping AND the first-signup onboarding ping.
# Must have one variable {{1}} = first name. Blank = both pings disabled.
WHATSAPP_WELCOME_TEMPLATE=        # e.g. pro_welcome
WHATSAPP_TEMPLATE_LANG=en         # template language code (e.g. en, en_US, ms)
